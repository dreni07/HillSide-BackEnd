APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Tesseract OCR (product image uploads). Windows: përdorni thonjëza dhe / (shmang \t në \tesseract): TESSERACT_EXECUTABLE="C:/Program Files (x86)/Tesseract-OCR/tesseract.exe"
TESSERACT_EXECUTABLE=tesseract
TESSERACT_LANGUAGES=eng

# URL publike e API-së për webhooks (Viber / proxy). Nëse bosh, përdoret APP_URL.
# PUBLIC_API_URL=https://api.example.com

# Meta webhooks: URL GET/POST {APP_URL}/api/webhooks/meta — verify token must match Meta Developer “Verify token”
META_WEBHOOK_VERIFY_TOKEN=
# META_WEBHOOK_SKIP_SIGNATURE=true  # vetëm për testim lokal (jo prodhim)
# OUTBOUND_SKIP_NETWORK=true  # CRM nuk thërret Messenger/WhatsApp/Viber (vetëm DB) — vetëm dev/test
# VIBER_SEND_URL=https://chatapi.viber.com/pa/send_message
# VIBER_SET_WEBHOOK_URL=https://chatapi.viber.com/pa/set_webhook
# META_APP_ID=  META_APP_SECRET=  META_REDIRECT_URI=  FRONTEND_URL=  (shih dokumentimin e projektit për OAuth)

# Groq / OpenAI-compatible chat API (strukturim produktesh nga teksti i nxjerrë)
AI_API_KEY=
AI_API_URL=https://api.groq.com/openai/v1
AI_MODEL=llama-3.3-70b-versatile
# AI_HTTP_TIMEOUT=120
# AI_MAX_INPUT_CHARS=48000
# AI_AUTO_REPLY_ENABLED=true  # pas mesazhit hyrës: radhë GenerateInboundAiReplyJob (kërkon worker + AiConfig aktiv për biznesin e përdoruesit të kanalit)

# Kanale: token-at në DB (CHANNEL_ENCRYPT_TOKENS=true) + log strukturor (opsionale CHANNEL_OPS_LOG_CHANNEL)
# CHANNEL_ENCRYPT_TOKENS=true   # prodhim: meta_access_token / webhook_verify_token të enkriptuara me APP_KEY
# CHANNEL_OPS_LOG_CHANNEL=stack  # ose emër kanali nga config/logging.php për [channel_ops] në log
